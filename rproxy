# ══════════════════════════════════════════════════════════════════════
# ПОЛУЧИТЬ SSL (Certbot)
# ══════════════════════════════════════════════════════════════════════
do_ssl_interactive() {
    clear_screen
    draw_box "Получить SSL сертификат (Certbot)"
    printf "\n"

    select_service "Выпуститиь SSL для" "all" || { pause; return; }
    local name="$SELECTED_SERVICE"
    [ "$name" = "__ALL__" ] && { warn "Выберите конкретный сервис"; pause; return; }

    load_service "$name" || { pause; return; }

    if [ -z "$SVC_DOMAIN" ]; then
        err "Для получения SSL сервису должен быть назначен домен"
        pause
        return
    fi

    if [ -z "$CERTBOT_EMAIL" ]; then
        prompt "Введите Email для регистрации в Certbot: "
        CERTBOT_EMAIL="$REPLY"
        sed -i "/CERTBOT_EMAIL=/d" "$CONF_FILE"
        echo "CERTBOT_EMAIL=\"$CERTBOT_EMAIL\"" >> "$CONF_FILE"
    fi

    msg "Проверяю наличие Certbot на VPS..."
    ssh_cmd "command -v certbot >/dev/null 2>&1 || (apt-get update -qq && apt-get install -y -qq certbot python3-certbot-nginx || yum install -y certbot python3-certbot-nginx)" || {
        warn "Не удалось автоматически установить Certbot на VPS"
    }

    msg "Проверяю наличие SSL для $SVC_DOMAIN на VPS..."
    if check_remote_ssl "$SVC_DOMAIN"; then
        msg "Обнаружен существующий сертификат! Перенастраиваю Nginx..."
        local tmp="/tmp/rproxy_ssl_$name.conf"
        local remote_path="$REMOTE_NGINX_DIR/rproxy_$name.conf"
        
        if [ "$SVC_TYPE" = "tcp" ]; then
            generate_nginx_stream_conf "$name" "$SVC_TUNNEL_PORT" "$SVC_EXT_PORT" "$tmp" "$SVC_DOMAIN"
            remote_path="$REMOTE_NGINX_STREAMS_DIR/rproxy_$name.conf"
        else
            generate_nginx_conf "$name" "$SVC_TARGET_HOST" "$SVC_TARGET_PORT" "$SVC_TUNNEL_PORT" "$SVC_DOMAIN" "$SVC_EXT_PORT" "$SVC_NDM_AUTH" "$tmp" "yes" "$SVC_TYPE"
        fi

        scp_cmd "$tmp" "$VPS_USER@$VPS_HOST:$remote_path"
        rm -f "$tmp"
        ssh_cmd "nginx -t" || { err "Ошибка конфигурации Nginx на VPS!"; return 1; }
ssh_cmd "systemctl reload nginx"
        msg "Nginx обновлен для использования существующего SSL."
        sed -i "s/SVC_SSL=.*/SVC_SSL=\"yes\"/" "$SERVICES_DIR/$name.conf"
    else
        msg "Запрашиваю новый сертификат для $SVC_DOMAIN..."
        if ssh_cmd "certbot --nginx -d $SVC_DOMAIN --non-interactive --agree-tos -m $CERTBOT_EMAIL"; then
            msg "SSL сертификат успешно получен!"
            sed -i "s/SVC_SSL=.*/SVC_SSL=\"yes\"/" "$SERVICES_DIR/$name.conf"
            ssh_cmd "systemctl is-active certbot.timer >/dev/null 2>&1 || (crontab -l 2>/dev/null | grep -q certbot || (crontab -l 2>/dev/null; echo \"0 0,12 * * * certbot renew -q\") | crontab -)"
        else
            err "Certbot не смог выпустить сертификат"
            warn "Убедитесь, что домен $SVC_DOMAIN указывает на этот VPS и порт 80 открыт"
        fi
    fi
    pause
}

# ══════════════════════════════════════════════════════════════════════
# ОБНОВЛЕНИЕ СКРИПТА
# ══════════════════════════════════════════════════════════════════════
do_self_update() {
    clear_screen
    draw_box "Обновление rProxy"
    printf "\n"
    
    printf "  Выберите версию для обновления:\n"
    printf "  ${BOLD}1)${NC}  Стабильная (ветка main)\n"
    printf "  ${BOLD}2)${NC}  Тестовая (ветка test-custom-ports)\n"
    printf "  ${BOLD}0)${NC}  Отмена\n"
    
    prompt "Выберите вариант: "
    local branch="main"
    case "$REPLY" in
        1) branch="main" ;;
        2) branch="test-custom-ports" ;;
        0|*) return ;;
    esac

    msg "Проверяю наличие обновлений в ветке '$branch'..."
    
    local url="https://raw.githubusercontent.com/l-ptrol/rProxy/$branch/rproxy"
    local tmp_file="/tmp/rproxy_update"
    
    if curl -sSL "$url" -o "$tmp_file"; then
        if [ -s "$tmp_file" ]; then
             mv "$tmp_file" "/opt/bin/rproxy"
             chmod +x "/opt/bin/rproxy"
             msg "Обновление из ветки '$branch' успешно завершено!"
             pause
             exec /opt/bin/rproxy # Перезапуск новой версии
        else
             err "Файл обновления пуст или не найден"
        fi
    else
        err "Не удалось загрузить обновление"
    fi
    pause
}

# ══════════════════════════════════════════════════════════════════════
# ПРОВЕРКА СОСТОЯНИЯ VPS
# ══════════════════════════════════════════════════════════════════════
do_health_check() {
    clear_screen
    draw_box "Состояние VPS и SSL"
    printf "\n"

    for f in "$VPS_DIR"/*.conf; do
        [ -f "$f" ] || continue
        local vps_id=$(basename "$f" .conf)
        load_vps "$vps_id"
        
        header "Сервер: $vps_id ($VPS_HOST)"
        
        msg "Проверяю Nginx..."
        if ssh_cmd "systemctl is-active nginx >/dev/null 2>&1"; then
            printf "  Nginx:        ${GREEN}${BOLD}Запущен${NC}\n"
        else
            printf "  Nginx:        ${RED}${BOLD}Остановлен${NC}\n"
        fi
        
        msg "Проверяю автопродление SSL (Certbot)..."
        local timer=$(ssh_cmd "systemctl is-active certbot.timer 2>/dev/null | tr -d '\r'")
        if [ "$timer" = "active" ]; then
            printf "  SSL Timer:    ${GREEN}${BOLD}Активен (Systemd)${NC}\n"
            local next_run=$(ssh_cmd "systemctl list-timers certbot.timer --no-legend 2>/dev/null | awk '{print \$1, \$2}'" | head -n 1)
            [ -n "$next_run" ] && printf "  Следующее:    $next_run\n"
        else
            if ssh_cmd "crontab -l 2>/dev/null | grep -q certbot"; then
                printf "  SSL Renewal:  ${GREEN}${BOLD}Настроено (Cron)${NC}\n"
            else
                printf "  SSL Renewal:  ${RED}${BOLD}Не обнаружено${NC}\n"
            fi
        fi
        
        msg "Действующие сертификаты:"
        local certs=$(ssh_cmd "certbot certificates 2>/dev/null | grep -E 'Expiry Date:|Domains:'")
        if [ -n "$certs" ]; then
            echo "$certs" | while read -r line; do
                printf "  %s\n" "$line"
            done
        else
            printf "  ${DIM}Сертификаты не найдены${NC}\n"
        fi
    done

    printf "\n"
    msg "Утилиты на роутере:"
    [ -x "/opt/bin/ssh" ] && printf "  SSH:          ${GREEN}Entware OK${NC}\n" || printf "  SSH:          ${RED}Missing${NC}\n"
    [ -x "/opt/bin/autossh" ] && printf "  AutoSSH:      ${GREEN}OK${NC}\n" || printf "  AutoSSH:      ${RED}Missing${NC}\n"
    
    pause
}

# ══════════════════════════════════════════════════════════════════════
# УДАЛИТЬ СЕРВИС (интерактивно)
# ══════════════════════════════════════════════════════════════════════
do_remove_interactive() {
    clear_screen
    draw_box "Удалить сервис"
    printf "\n"

    select_service "Выберите сервис для удаления" "all" || { pause; return; }
    local selected="$SELECTED_SERVICE"
    
    if [ "$selected" = "__ALL__" ]; then
        prompt "Удалить ВСЕ сервисы? (д/н) [н]: "
        case "${REPLY:-н}" in
            д|Д|y|Y|да|yes) ;;
            *) msg "Отменено"; pause; return ;;
        esac
        
        for f in "$SERVICES_DIR"/*.conf; do
            [ -f "$f" ] || continue
            local name=$(basename "$f" .conf)
            msg "Удаление сервиса '$name'..."
            (
                load_service "$name" || exit 1
                is_running "$name" && do_stop_service "$name"

                ssh_cmd "rm -f $REMOTE_NGINX_DIR/rproxy_$name.conf $REMOTE_NGINX_STREAMS_DIR/rproxy_$name.conf /etc/nginx/rproxy_$name.htpasswd"
                ssh_cmd "nginx -t" && ssh_cmd "systemctl reload nginx"
                rm -f "$SERVICES_DIR/$name.conf"
                rm -f "$(get_pid_file "$name")"
            )
            msg "Сервис '$name' удалён"
        done
    else
        # Удаление выбранных сервисов
        for name in $selected; do
            msg "Удаление сервиса '$name'..."
            (
                load_service "$name" || exit 1
                is_running "$name" && do_stop_service "$name"

                ssh_cmd "rm -f $REMOTE_NGINX_DIR/rproxy_$name.conf $REMOTE_NGINX_STREAMS_DIR/rproxy_$name.conf /etc/nginx/rproxy_$name.htpasswd && nginx -t && systemctl reload nginx" >/dev/null 2>&1
                rm -f "$SERVICES_DIR/$name.conf"
                rm -f "$(get_pid_file "$name")"
            )
            msg "Сервис '$name' удалён"
        done
    fi
    pause
}

# ══════════════════════════════════════════════════════════════════════
# РЕДАКТИРОВАТЬ СЕРВИС (интерактивно)
# ══════════════════════════════════════════════════════════════════════
do_edit_interactive() {
    while true; do
        clear_screen
        draw_box "Редактировать сервис"
        printf "\n"

        select_service "Выберите сервис для редактирования" "all" || return
        local name="$SELECTED_SERVICE"
        [ "$name" = "__ALL__" ] && { warn "Для редактирования выберите конкретный сервис"; pause; continue; }

        load_service "$name" || { pause; continue; }

        header "Редактирование: $name"
        printf "  ${DIM}Текущие параметры:${NC}\n"
        printf "  Цель:          ${BOLD}$SVC_TARGET_HOST:$SVC_TARGET_PORT${NC}\n"
        printf "  Туннель:       порт ${BOLD}$SVC_TUNNEL_PORT${NC}\n"
        [ -n "$SVC_DOMAIN" ] && printf "  Домен:         ${BOLD}$SVC_DOMAIN${NC}\n"
        printf "  Внешний порт:  ${BOLD}$SVC_EXT_PORT${NC}\n"
        draw_separator

        prompt "Новый адрес (IP:порт) [$SVC_TARGET_HOST:$SVC_TARGET_PORT] (0 - назад): "
        [ "$REPLY" = "0" ] && continue
        local new_target="${REPLY:-$SVC_TARGET_HOST:$SVC_TARGET_PORT}"

        local new_host="${new_target%:*}"
        local new_port="${new_target#*:}"
        if [ "$new_host" = "$new_port" ]; then
            new_port="$new_host"
            new_host="127.0.0.1"
        fi

        local new_ext_port="$SVC_EXT_PORT"
        if [ -n "$SVC_DOMAIN" ]; then
            prompt "Новый внешний порт [$SVC_EXT_PORT] (0 - назад): "
            [ "$REPLY" = "0" ] && continue
            new_ext_port="${REPLY:-$SVC_EXT_PORT}"
        fi

        local new_ttyd_cmd="$SVC_TTYD_CMD"
        if [ "$SVC_TYPE" = "ttyd" ]; then
            if build_ttyd_command_interactive "$SVC_TTYD_CMD"; then
                new_ttyd_cmd="$TTYD_CMD_RESULT"
            else
                continue
            fi
        fi

        local new_auth_enabled="$SVC_NDM_AUTH"
        local new_htpasswd="$SVC_HTPASSWD"
        local auth_changed=0

        printf "  Защита паролем:  ${BOLD}%s${NC}\n" "$SVC_NDM_AUTH"
        prompt "Изменить настройки авторизации? (д/н) [н]: "
        if [ "${REPLY:-н}" = "д" ] || [ "${REPLY:-н}" = "y" ]; then
            if select_auth_interactive; then
                new_auth_enabled="$AUTH_RESULT_ENABLED"
                new_htpasswd="$AUTH_RESULT_HTPASSWD"
                auth_changed=1
            fi
        fi

        # Если ничего не изменилось
        if [ "$new_host" = "$SVC_TARGET_HOST" ] && [ "$new_port" = "$SVC_TARGET_PORT" ] && \
           [ "$new_ext_port" = "$SVC_EXT_PORT" ] && [ "$new_ttyd_cmd" = "$SVC_TTYD_CMD" ] && \
           [ "$auth_changed" -eq 0 ]; then
            msg "Параметры не изменились."
            pause
            continue
        fi

        printf "\n"
        draw_separator
        printf "  ${DIM}Было:${NC}   $SVC_TARGET_HOST:$SVC_TARGET_PORT (внешний: $SVC_EXT_PORT) Auth: $SVC_NDM_AUTH"
        [ "$SVC_TYPE" = "ttyd" ] && printf " [CMD: $SVC_TTYD_CMD]"
        printf "\n"
        printf "  ${GREEN}Стало:${NC}  $new_host:$new_port (внешний: $new_ext_port) Auth: $new_auth_enabled"
        [ "$SVC_TYPE" = "ttyd" ] && printf " [CMD: $new_ttyd_cmd]"
        printf "\n"
        draw_separator

        prompt "Применить изменения? (д/н) [д]: "
        [ "$REPLY" = "0" ] && continue
        case "${REPLY:-д}" in
            д|Д|y|Y|да|yes) ;;
            *) msg "Отменено"; pause; continue ;;
        esac

    printf "\n"
    msg "Применяю изменения и обновляю VPS..."

    # Остановить туннель если запущен
    local was_running=0
    if is_running "$name"; then
        was_running=1
        do_stop_service "$name"
    fi

    local tmp="/tmp/rproxy_edit_$name.conf"
    local remote_path="$REMOTE_NGINX_DIR/rproxy_$name.conf"

    if [ "$SVC_TYPE" = "tcp" ]; then
        generate_nginx_stream_conf "$name" "$SVC_TUNNEL_PORT" "$new_ext_port" "$tmp" "$SVC_DOMAIN"
        remote_path="$REMOTE_NGINX_STREAMS_DIR/rproxy_$name.conf"
    else
        generate_nginx_conf "$name" "$new_host" "$new_port" "$SVC_TUNNEL_PORT" "$SVC_DOMAIN" "$new_ext_port" "$new_auth_enabled" "$tmp" "$SVC_SSL" "$SVC_TYPE"
    fi

    scp_cmd "$tmp" "$VPS_USER@$VPS_HOST:$remote_path"
    rm -f "$tmp"

    # Обработка .htpasswd
    if [ "$new_auth_enabled" = "yes" ] && [ "$auth_changed" -eq 1 ]; then
        local ht_tmp="/tmp/rproxy_edit_$name.htpasswd"
        echo "$new_htpasswd" > "$ht_tmp"
        scp_cmd "$ht_tmp" "$VPS_USER@$VPS_HOST:/etc/nginx/rproxy_$name.htpasswd"
        rm -f "$ht_tmp"
    fi
    # Если отключили авторизацию - удаляем файл на VPS (опционально, но лучше для чистоты)
    if [ "$new_auth_enabled" = "no" ] && [ "$SVC_NDM_AUTH" = "yes" ]; then
        ssh_cmd "rm -f /etc/nginx/rproxy_$name.htpasswd"
    fi
    ssh_cmd "nginx -t" || { err "Ошибка конфигурации Nginx на VPS!"; return 1; }
ssh_cmd "systemctl reload nginx"

    # Обновляем конфиг локально
    sed -i "s/SVC_TARGET_HOST=.*/SVC_TARGET_HOST=\"$new_host\"/" "$SERVICES_DIR/$name.conf"
    sed -i "s/SVC_TARGET_PORT=.*/SVC_TARGET_PORT=\"$new_port\"/" "$SERVICES_DIR/$name.conf"
    sed -i "s/SVC_EXT_PORT=.*/SVC_EXT_PORT=\"$new_ext_port\"/" "$SERVICES_DIR/$name.conf"
    sed -i "s/SVC_NDM_AUTH=.*/SVC_NDM_AUTH=\"$new_auth_enabled\"/" "$SERVICES_DIR/$name.conf"
    if [ "$auth_changed" -eq 1 ]; then
        sed -i "/SVC_HTPASSWD=/d" "$SERVICES_DIR/$name.conf"
        printf "SVC_HTPASSWD='%s'\n" "$new_htpasswd" >> "$SERVICES_DIR/$name.conf"
    fi
    if [ "$SVC_TYPE" = "ttyd" ]; then
        if grep -q "SVC_TTYD_CMD=" "$SERVICES_DIR/$name.conf"; then
            sed -i "s|SVC_TTYD_CMD=.*|SVC_TTYD_CMD=\"$new_ttyd_cmd\"|" "$SERVICES_DIR/$name.conf"
        else
            echo "SVC_TTYD_CMD=\"$new_ttyd_cmd\"" >> "$SERVICES_DIR/$name.conf"
        fi
    fi

    msg "Сервис '$name' обновлен"
    [ "$was_running" -eq 1 ] && do_start_service "$name"
    pause
    done
}

# ══════════════════════════════════════════════════════════════════════
# ВЫБОР СЕРВИСА (общий)
# ══════════════════════════════════════════════════════════════════════
select_service() {
    local title="$1"
    local filter="$2"  # all, running, stopped

    local services=""
    local idx=0
    for f in "$SERVICES_DIR"/*.conf; do
        [ -f "$f" ] || continue
        # Не загружаем весь конфиг здесь, чтобы не перезатирать глобальные SVC_* если не надо
        local s_name=$(basename "$f" .conf)
        
        local running=0
        is_running "$s_name" && running=1

        # Фильтр
        case "$filter" in
            running) [ "$running" -eq 0 ] && continue ;;
            stopped) [ "$running" -eq 1 ] && continue ;;
        esac

        idx=$((idx + 1))
        local st="${RED}○${NC}"
        [ "$running" -eq 1 ] && st="${GREEN}●${NC}"
        
        # Получаем данные для отображения без полной загрузки (быстрее)
        local s_target_host=$(grep 'SVC_TARGET_HOST=' "$f" | cut -d'"' -f2)
        local s_target_port=$(grep 'SVC_TARGET_PORT=' "$f" | cut -d'"' -f2)
        local s_domain=$(grep 'SVC_DOMAIN=' "$f" | cut -d'"' -f2)

        printf "  ${BOLD}%d)${NC}  %b  %-14s  %s:%s" "$idx" "$st" "$s_name" "$s_target_host" "$s_target_port"
        [ -n "$s_domain" ] && printf "  ${DIM}(%s)${NC}" "$s_domain"
        printf "\n"
        [ -z "$services" ] && services="$s_name" || services="$services $s_name"
    done

    if [ "$idx" -eq 0 ]; then
        printf "  ${YELLOW}Нет подходящих сервисов.${NC}\n"
        SELECTED_SERVICE=""
        return 1
    fi

    draw_separator
    printf "  ${BOLD}903)${NC} Все сервисы\n"
    printf "  ${BOLD}0)${NC}   Назад\n"
    while true; do
        prompt "Выберите номер(а) (через пробел или 903): "

        [ "$REPLY" = "0" ] && { SELECTED_SERVICE=""; return 1; }
        if [ "$REPLY" = "903" ]; then
            SELECTED_SERVICE="__ALL__"
            return 0
        fi

        # Поддержка ввода нескольких номеров через пробел
        local sel_names=""
        local valid=0
        for r in $REPLY; do
            if echo "$r" | grep -qE '^[0-9]+$'; then
                local n=$(echo "$services" | cut -d' ' -f"$r")
                if [ -n "$n" ]; then
                    [ -z "$sel_names" ] && sel_names="$n" || sel_names="$sel_names $n"
                    valid=1
                fi
            fi
        done

        if [ "$valid" -eq 1 ]; then
            SELECTED_SERVICE="$sel_names"
            return 0
        fi
        warn "Неверный выбор. Попробуйте еще раз."
    done
}

# ══════════════════════════════════════════════════════════════════════
# ЗАПУСК / ОСТАНОВ / ПЕРЕЗАПУСК (интерактивно)
# ══════════════════════════════════════════════════════════════════════
do_start_interactive() {
    clear_screen
    draw_box "Запустить туннель"
    printf "\n"
    select_service "Запустить" "stopped" || { pause; return; }

    if [ "$SELECTED_SERVICE" = "__ALL__" ]; then
        do_start_all
    else
        for name in $SELECTED_SERVICE; do
            do_start_service "$name"
        done
    fi
    pause
}

do_stop_interactive() {
    clear_screen
    draw_box "Остановить туннель"
    printf "\n"
    select_service "Остановить" "running" || { pause; return; }

    if [ "$SELECTED_SERVICE" = "__ALL__" ]; then
        do_stop_all
    else
        for name in $SELECTED_SERVICE; do
            do_stop_service "$name"
        done
    fi
    pause
}

do_restart_interactive() {
    clear_screen
    draw_box "Перезапустить туннель"
    printf "\n"
    select_service "Перезапустить" "all" || { pause; return; }

    if [ "$SELECTED_SERVICE" = "__ALL__" ]; then
        for f in "$SERVICES_DIR"/*.conf; do
            [ -f "$f" ] || continue
            local s_name=$(basename "$f" .conf)
            do_stop_service "$s_name"
            sleep 1
            do_start_service "$s_name"
        done
    else
        for name in $SELECTED_SERVICE; do
            do_stop_service "$name"
            sleep 1
            do_start_service "$name"
        done
    fi
    pause
}

# ══════════════════════════════════════════════════════════════════════
# ЗАПУСК / ОСТАНОВ (одного сервиса)
# ══════════════════════════════════════════════════════════════════════
# ══════════════════════════════════════════════════════════════════════
# УПРАВЛЕНИЕ TTYD
# ══════════════════════════════════════════════════════════════════════
# Внутренняя функция проверки занятости порта (совместимость ss/netstat)
_is_port_busy() {
    local port="$1"
    if command -v ss >/dev/null 2>&1; then
        ss -tln | grep -q ":$port "
    elif command -v netstat >/dev/null 2>&1; then
        netstat -tnl | grep -q ":$port "
    else
        # Если нет ничего, считаем порт свободным (рискованно, но лучше чем падение)
        return 1
    fi
}

start_ttyd() {
    local port="${1:-7681}"
    local cmd="${SVC_TTYD_CMD:-login}"
    local log="/tmp/rproxy_ttyd_${port}.log"
    local pid_file="/opt/var/run/rproxy/ttyd_${port}.pid"
    
    # 0️⃣ Динамический поиск бинарника
    local ttyd_bin=""
    if command -v ttyd >/dev/null 2>&1; then
        ttyd_bin=$(command -v ttyd)
    elif [ -x "/opt/bin/ttyd" ]; then
        ttyd_bin="/opt/bin/ttyd"
    else
        msg "ttyd не найден. Попытка установки..."
        opkg update >/dev/null 2>&1
        opkg install ttyd >/dev/null 2>&1
        ttyd_bin=$(command -v ttyd || echo "/opt/bin/ttyd")
    fi

    if [ ! -x "$ttyd_bin" ]; then
        err "Критическая ошибка: бинарник ttyd не найден!"
        return 1
    fi

    local setsid_bin=""
    command -v setsid >/dev/null 2>&1 && setsid_bin="setsid"

    msg "Запуск ttyd терминала с Watchdog (Изолированный)..."
    msg "Бинарник: $ttyd_bin"
    msg "Порт: $port"

    mkdir -p /opt/var/run/rproxy

    # 1️⃣ Проверка доступности порта
    if _is_port_busy "$port"; then
        warn "Порт $port уже занят, ttyd не может быть запущен."
        return 1
    fi

    # 2️⃣ Агрессивная очистка
    [ -f "$pid_file" ] && { kill -TERM "$(cat "$pid_file")" 2>/dev/null; rm -f "$pid_file"; }
    
    # Уничтожаем все старые экземпляры Watchdog и ttyd для этого порта
    pkill -9 -f "rproxy.*ttyd.*-p $port" >/dev/null 2>&1
    pkill -9 -f "ttyd.*-p $port" >/dev/null 2>&1
    fuser -k ${port}/tcp >/dev/null 2>&1
    sleep 1

    # 3️⃣ Watchdog Launcher
    (
        trap 'exit 0' TERM INT
        
        while true; do
            if [ -x "$ttyd_bin" ]; then
                # Запуск без env -i и setsid для сохранения TTY/PTY
                "$ttyd_bin" -W --max-clients 10 -i 0.0.0.0 -p "$port" -- $cmd >> "$log" 2>&1
            else
                echo "$(date) Error: ttyd lost during runtime!" >> "$log"
                exit 1
            fi
            
            local exit_code=$?
            echo "$(date) ttyd stopped with exit code $exit_code, restarting in 2s..." >> "$log"
            sleep 2
        done
    ) &

    local watchdog_pid=$!
    echo "$watchdog_pid" > "$pid_file"

    # 4️⃣ Верификация старта
    msg "Верификация запуска..."
    local start_ok=0
    for i in 1 2 3 4 5; do
        if _is_port_busy "$port"; then
            start_ok=1
            break
        fi
        sleep 1
    done

    if [ $start_ok -eq 1 ]; then
        msg "ttyd успешно запущен (Watchdog PID $watchdog_pid)"
        return 0
    else
        err "ttyd не смог открыть порт за 5 секунд. Отмена."
        kill -TERM "$watchdog_pid" 2>/dev/null
        rm -f "$pid_file"
        # Убиваем возможные остатки процесса
        pkill -9 -f "ttyd.*-p $port" >/dev/null 2>&1
        fuser -k ${port}/tcp >/dev/null 2>&1
        [ -s "$log" ] && tail -n 15 "$log"
        return 1
    fi
}

stop_ttyd() {
    local port="${1:-7681}"
    local pid_file="/opt/var/run/rproxy/ttyd_${port}.pid"

    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")
        msg "Остановка Watchdog ttyd (PID $pid)..."
        kill -TERM "$pid" 2>/dev/null
        rm -f "$pid_file"
    fi
    pkill -9 -f "rproxy.*ttyd.*-p $port" >/dev/null 2>&1
    pkill -9 -f "ttyd.*-p $port" >/dev/null 2>&1
    fuser -k ${port}/tcp >/dev/null 2>&1
}

do_start_service() {
    local name="$1"
    load_service "$name" || return

    local lock_file="$LOCK_DIR/$name.lock"
    if [ -f "$lock_file" ]; then
        warn "Сервис '$name' уже запускается (lock-файл существует)."
        return
    fi
    touch "$lock_file"
    trap 'rm -f "$lock_file"' EXIT

    if is_running "$name"; then
        msg "Сервис '$name' уже запущен."
        rm -f "$lock_file"
        return
    fi

    msg "Запускаю туннель '$name' ($SVC_TARGET_HOST:$SVC_TARGET_PORT → VPS:$SVC_TUNNEL_PORT)..."

    # Динамический порт для ttyd
    if [ "$SVC_TYPE" = "ttyd" ]; then
        if start_ttyd; then
            # По умолчанию пользователь использует 7681
            SVC_TARGET_PORT=7681
            SVC_TARGET_HOST="127.0.0.1"
        else
            rm -f "$lock_file"
            return 1
        fi
    fi

    local ssh_exec="/opt/bin/ssh"
    [ ! -f "$ssh_exec" ] && ssh_exec="ssh"
    export AUTOSSH_PATH="$ssh_exec"

    msg "Проверка порта $SVC_TUNNEL_PORT на VPS..."
    # Универсальная проверка (fallback: ss -> netstat)
    if ssh_cmd "ss -tln | grep -q ':$SVC_TUNNEL_PORT ' || netstat -tnl | grep -q ':$SVC_TUNNEL_PORT '"; then
        warn "Порт $SVC_TUNNEL_PORT на VPS уже занят. Пытаюсь освободить..."
        ssh_cmd "fuser -k $SVC_TUNNEL_PORT/tcp >/dev/null 2>&1 || true"
        sleep 1
    fi

    local ssh_opts="-o StrictHostKeyChecking=no -o ServerAliveInterval=10 -o ServerAliveCountMax=3 -o ConnectTimeout=10 -o ExitOnForwardFailure=yes"
    local tunnel_args="-R 0.0.0.0:$SVC_TUNNEL_PORT:$SVC_TARGET_HOST:$SVC_TARGET_PORT"
    
    # Мониторинг порт для autossh (20000 + случайное число)
    local mon_port=$((20000 + RANDOM % 1000))

    if [ "$VPS_AUTH" = "password" ]; then
        AUTOSSH_GATETIME=0 sshpass -p "$VPS_PASS" autossh -M "$mon_port" -f -N \
            $ssh_opts \
            -p "$VPS_PORT" \
            $tunnel_args \
            "$VPS_USER@$VPS_HOST" &
    else
        AUTOSSH_GATETIME=0 autossh -M "$mon_port" -f -N \
            $ssh_opts \
            -i "$SSH_KEY" \
            -p "$VPS_PORT" \
            $tunnel_args \
            "$VPS_USER@$VPS_HOST" &
    fi

    local bg_pid=$!
    # Трюк для получения реального PID autossh, если он ушел в форк
    sleep 2
    local real_pid
    real_pid=$(pgrep -f "autossh.*-M $mon_port")
    [ -z "$real_pid" ] && real_pid=$bg_pid

    echo "$real_pid" > "$(get_pid_file "$name")"
    msg "Туннель '$name' запущен (PID: $real_pid, MonPort: $mon_port)"

    # Вывод подсказки для подключения
    if [ "$SVC_TYPE" = "ttyd" ]; then
        local proto="http"
        [ "$SVC_SSL" = "yes" ] && proto="https"
        local url="$proto://$SVC_DOMAIN"
        [ "$SVC_EXT_PORT" != "80" ] && [ "$SVC_EXT_PORT" != "443" ] && url="$url:$SVC_EXT_PORT"
        [ -z "$SVC_DOMAIN" ] && url="$proto://$VPS_HOST:$SVC_EXT_PORT"

        draw_separator
        printf "  ${BOLD}Веб-терминал (ttyd) доступен по адресу:${NC}\n"
        printf "  ${CYAN}$url${NC}\n"
        draw_separator
    elif [ "$SVC_TYPE" = "tcp" ] || [ "$SVC_TYPE" = "ssh" ] || [ "$SVC_TYPE" = "http" ]; then
        draw_separator
        printf "  ${BOLD}Инструкция по подключению:${NC}\n"
        if [ "$SVC_TYPE" = "tcp" ] || [ "$SVC_TYPE" = "ssh" ]; then
             if [ -n "$SVC_DOMAIN" ]; then
                 if [ "$SVC_SSL" = "yes" ]; then
                     printf "  ${DIM}Через ProxyCommand (SSL):${NC}\n"
                     printf "  ssh -o ProxyCommand=\"openssl s_client -quiet -connect $SVC_DOMAIN:$SVC_EXT_PORT\" root@$SVC_TARGET_HOST\n"
                 else
                     printf "  ssh root@$SVC_DOMAIN -p $SVC_EXT_PORT\n"
                 fi
             else
                 printf "  ssh root@$VPS_HOST -p $SVC_EXT_PORT\n"
             fi
        else
             local proto="http"
             [ "$SVC_SSL" = "yes" ] && proto="https"
             local url="$proto://$SVC_DOMAIN"
             [ "$SVC_EXT_PORT" != "80" ] && [ "$SVC_EXT_PORT" != "443" ] && url="$url:$SVC_EXT_PORT"
             [ -z "$SVC_DOMAIN" ] && url="$proto://$VPS_HOST:$SVC_EXT_PORT"
             printf "  Доступен по адресу: ${CYAN}$url${NC}\n"
        fi
        draw_separator
    fi

    rm -f "$lock_file"
}

do_stop_service() {
    local name="$1"
    load_service "$name" || return
    
    local pid_file
    pid_file=$(get_pid_file "$name")

    # Сначала проверяем туннель
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        msg "Остановка туннеля '$name' (PID: $pid)..."
        kill "$pid" 2>/dev/null
        # Если туннель не умер — форсируем
        sleep 1
        kill -9 "$pid" 2>/dev/null
        rm -f "$pid_file"
    else
        warn "PID-файл туннеля '$name' не найден"
    fi

    # Теперь ttyd если был
    if [ "$SVC_TYPE" = "ttyd" ]; then
        stop_ttyd
    fi

    msg "Сервис '$name' остановлен"
}

_clear_svc_vars() {
    unset SVC_NAME SVC_VPS SVC_TARGET_HOST SVC_TARGET_PORT SVC_TUNNEL_PORT
    unset SVC_EXT_PORT SVC_DOMAIN SVC_SSL SVC_NDM_AUTH SVC_HTPASSWD SVC_TYPE SVC_TTYD_CMD SVC_ENABLED
}

load_service() {
    _clear_svc_vars
    local f="$SERVICES_DIR/$1.conf"
    [ -f "$f" ] || return 1
    . "$f"
    load_vps "$SVC_VPS"
}

check_remote_ssl() {
    local domain="$1"
    # Проверяем наличие папки сертификата в LetsEncrypt на VPS
    ssh_cmd "[ -d /etc/letsencrypt/live/$domain ]" >/dev/null 2>&1
}

generate_nginx_stream_conf() {
    local name="$1"
    local tunnel_port="$2"
    local ext_port="$3"
    local target_file="$4"
    local domain="$5"

    if [ -n "$domain" ]; then
        # Для TCP через домен используем SSL с расширенными настройками
        cat > "$target_file" << NGINXEOF
server {
    listen $ext_port ssl;
    proxy_pass 127.0.0.1:$tunnel_port;

    ssl_certificate /etc/letsencrypt/live/$domain/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/$domain/privkey.pem;
    
    # Расширенные настройки SSL для стабильности TCP-потока
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_handshake_timeout 15s;
    ssl_session_cache shared:SSLSTREAM:10m;
    ssl_session_timeout 1h;
}
NGINXEOF
    else
        cat > "$target_file" << NGINXEOF
server {
    listen $ext_port;
    proxy_pass 127.0.0.1:$tunnel_port;
}
NGINXEOF
    fi
}

generate_nginx_conf() {
    local name="$1"
    local t_host="$2"
    local t_port="$3"
    local tunnel_port="$4"
    local domain="$5"
    local ext_port="$6"
    local use_ndm_auth="$7"
    local target_file="$8"
    local use_ssl="${9:-no}"
    local type="${10:-http}"

    local stealth_host="$t_host"
    [ "$t_port" != "80" ] && stealth_host="$t_host:$t_port"
    
    local auth_config=""
    if [ "$use_ndm_auth" = "yes" ]; then
        auth_config="
    auth_basic \"Restricted Access\";
    auth_basic_user_file /etc/nginx/rproxy_$name.htpasswd;
    "
    fi

    if [ -n "$domain" ]; then
        # Если домен указан, проверяем наличие SSL сертификата на VPS
        local has_ssl=0
        check_remote_ssl "$domain" && has_ssl=1
        
        # Для доменов используем SSL по умолчанию, если он есть или если явно включен
        if [ "$has_ssl" = "1" ] || [ "$use_ssl" = "yes" ]; then
            local listen_opts="$ext_port ssl"
            [ "$ext_port" = "443" ] || listen_opts="$ext_port ssl"
            
            cat > "$target_file" << NGINXEOF
server {
    listen $listen_opts;
    server_name "$domain";
    proxy_buffering off;
    proxy_request_buffering off;
    
    ssl_certificate /etc/letsencrypt/live/$domain/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/$domain/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        $auth_config
        proxy_pass http://127.0.0.1:$tunnel_port;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-Port \$server_port;
        proxy_cookie_domain "$t_host" "\$host";
        proxy_set_header Origin "";
        proxy_read_timeout 7d;
        proxy_send_timeout 7d;
    }

    # Автоматический редирект HTTP -> HTTPS на кастомных портах (400 -> 301)
    error_page 497 301 =307 https://\$host:\$server_port\$request_uri;
}
NGINXEOF
            # Добавляем редирект с 80 порта на этот домен, если это 443
            if [ "$ext_port" = "443" ]; then
                cat >> "$target_file" << NGINXEOF
server {
    listen 80;
    server_name "$domain";
    return 301 https://\$host\$request_uri;
}
NGINXEOF
            fi
        else
            # Если SSL еще нет и не включен явно — создаем временный 80/ext_port для Certbot
            cat > "$target_file" << NGINXEOF
server {
    listen $ext_port;
    server_name "$domain";
    proxy_buffering off;
    proxy_request_buffering off;
    location / {
        $auth_config
        proxy_pass http://127.0.0.1:$tunnel_port;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-Port \$server_port;
        proxy_cookie_domain "$t_host" "\$host";
        proxy_set_header Origin "";
        proxy_read_timeout 7d;
        proxy_send_timeout 7d;
    }

    # Автоматический редирект HTTP -> HTTPS на кастомных портах (400 -> 301)
    error_page 497 301 =307 https://\$host:\$server_port\$request_uri;
}
NGINXEOF
        fi
    else
        cat > "$target_file" << NGINXEOF
server {
    listen $ext_port;
    proxy_buffering off;
    proxy_request_buffering off;
    location / {
        $auth_config
        proxy_pass http://127.0.0.1:$tunnel_port;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host "$stealth_host";
        proxy_set_header Origin "";
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Port \$server_port;
        proxy_cookie_domain "$t_host" "\$host";
        proxy_read_timeout 7d;
        proxy_send_timeout 7d;
    }
}
NGINXEOF
    fi
}

do_start_all() {
    for f in "$SERVICES_DIR"/*.conf; do
        [ -f "$f" ] || continue
        . "$f"
        [ "$SVC_ENABLED" = "yes" ] && do_start_service "$SVC_NAME"
    done
}

do_stop_all() {
    for f in "$SERVICES_DIR"/*.conf; do
        [ -f "$f" ] || continue
        . "$f"
        do_stop_service "$SVC_NAME"
    done
}

# ══════════════════════════════════════════════════════════════════════
# НАСТРОЙКА VPS (Менеджер профилей)
# ══════════════════════════════════════════════════════════════════════
do_setup() {
    while true; do
        clear_screen
        draw_box "Управление VPS серверами"
        printf "\n"

        local vps_list=""
        local idx=0
        for f in "$VPS_DIR"/*.conf; do
            [ -f "$f" ] || continue
            idx=$((idx + 1))
            VPS_HOST="" # Сброс перед загрузкой
            . "$f"
            local v_info="${DIM}${VPS_USER}@${VPS_HOST}:${VPS_PORT}${NC}"
            [ -z "$VPS_HOST" ] && v_info="${RED}Не настроен${NC}"
            printf "  ${BOLD}%d)${NC}  %-14s %b\n" "$idx" "$(basename "$f" .conf)" "$v_info"
            vps_list="$vps_list $(basename "$f" .conf)"
        done

        if [ "$idx" -eq 0 ]; then
            printf "  ${YELLOW}Нет настроенных VPS серверов.${NC}\n"
        fi

        draw_separator
        printf "  ${BOLD}901)${NC} ➕  Добавить новый VPS\n"
        [ "$idx" -gt 0 ] && printf "  ${BOLD}902)${NC} ❌  Удалить VPS\n"
        [ "$idx" -gt 0 ] && printf "  ${BOLD}903)${NC} 🧹  Очистить VPS от мусора (фантомные конфиги)\n"
        printf "  ${BOLD}904)${NC} 🔑  Пароль публикации по умолчанию\n"
        printf "  ${BOLD}0)${NC}   Назад\n"
        
        prompt "Выберите действие: "
        case "$REPLY" in
            0) return ;;
            901) do_add_vps ;;
            902) [ "$idx" -gt 0 ] && do_delete_vps_interactive "$vps_list" ;;
            903) [ "$idx" -gt 0 ] && do_vps_cleanup_menu "$vps_list" ;;
            904) do_change_auth_defaults ;;
            [1-9]*)
                local sel_vps=$(echo "$vps_list" | cut -d' ' -f"$REPLY")
                [ -n "$sel_vps" ] && do_add_vps "$sel_vps"
                ;;
        esac
    done
}

do_delete_vps_interactive() {
    local list="$1"
    prompt "Введите номер VPS для удаления: "
    local sel_vps=$(echo "$list" | cut -d' ' -f"$REPLY")
    [ -z "$sel_vps" ] && { warn "Неверный выбор"; pause; return; }

    prompt "Удалить профиль VPS '$sel_vps'? (д/н) [н]: "
    case "$REPLY" in
        д|Д|y|Y) rm -f "$VPS_DIR/$sel_vps.conf"; msg "Удалено" ;;
        *) msg "Отменено" ;;
    esac
    pause
}

do_vps_cleanup_menu() {
    local list="$1"
    prompt "Введите номер VPS для очистки: "
    local sel_vps=$(echo "$list" | cut -d' ' -f"$REPLY")
    [ -z "$sel_vps" ] && { warn "Неверный выбор"; pause; return; }
    
    do_vps_cleanup_interactive "$sel_vps"
}

do_vps_cleanup_interactive() {
    local vps_id="$1"
    load_vps "$vps_id" || return

    clear_screen
    draw_box "Очистка VPS: $vps_id ($VPS_HOST)"
    printf "\n"
    
    msg "Сканирую VPS на наличие конфигураций rProxy..."
    local remote_files
    remote_files=$(ssh_cmd "ls $REMOTE_NGINX_DIR/rproxy_*.conf /etc/nginx/rproxy_*.htpasswd 2>/dev/null | xargs -n1 basename 2>/dev/null")

    if [ -z "$remote_files" ]; then
        msg "На сервере не обнаружено файлов rProxy."
        pause
        return
    fi

    local to_delete=""
    local local_found=""
    
    header "Обнаруженные файлы на VPS:"
    echo "$remote_files" | while read -r line; do
        # Извлекаем имя сервиса из rproxy_NAME.conf или rproxy_NAME.htpasswd
        local s_name=$(echo "$line" | sed -E 's/^rproxy_(.+)\.(conf|htpasswd)$/\1/')
        
        if [ -f "$SERVICES_DIR/$s_name.conf" ]; then
            printf "  ${GREEN}●${NC} %-30s (Активен локально)\n" "$line"
        else
            printf "  ${RED}○${NC} %-30s (ФАНТОМНЫЙ - нет на роутере)\n" "$line"
            local_found="1"
        fi
    done

    draw_separator
    printf "  ${BOLD}1)${NC} 🧹  Умная очистка (удалить только фантомные файлы)\n"
    printf "  ${BOLD}2)${NC} 🔥  Полная очистка (удалить ВСЕ конфиги rProxy на этом VPS)\n"
    printf "  ${BOLD}0)${NC}     Отмена\n"
    
    prompt "Выберите действие: "
    case "$REPLY" in
        1)
            msg "Выполняю умную очистку..."
            echo "$remote_files" | while read -r line; do
                local s_name=$(echo "$line" | sed -E 's/^rproxy_(.+)\.(conf|htpasswd)$/\1/')
                if [ ! -f "$SERVICES_DIR/$s_name.conf" ]; then
                    msg "Удаляю $line..."
                    ssh_cmd "rm -f $REMOTE_NGINX_DIR/$line /etc/nginx/$line" >/dev/null 2>&1
                fi
            done
            ssh_cmd "nginx -t && systemctl reload nginx" >/dev/null 2>&1
            msg "Готово!"
            ;;
        2)
            prompt "Это удалит ВСЕ публикации rProxy на этом VPS. Уверены? (y/n): "
            [ "$REPLY" != "y" ] && { msg "Отменено"; pause; return; }
            msg "Полная очистка..."
            ssh_cmd "rm -f $REMOTE_NGINX_DIR/rproxy_*.conf /etc/nginx/rproxy_*.htpasswd && nginx -t && systemctl reload nginx" >/dev/null 2>&1
            msg "Все конфигурации rProxy на VPS '$vps_id' удалены."
            ;;
        *) msg "Отменено" ;;
    esac
    pause
}

do_change_auth_defaults() {
    draw_box "Настройки публикации (Basic Auth)"
    printf "\n"
    printf "  Эти данные будут предлагаться при защите новых сервисов.\n"
    
    prompt "Имя пользователя [${DEFAULT_AUTH_USER:-admin}]: "
    local user="${REPLY:-${DEFAULT_AUTH_USER:-admin}}"
    
    prompt "Пароль (оставьте пустым чтобы не менять): "
    local pass="$REPLY"
    
    if [ -z "$pass" ] && [ -n "$DEFAULT_AUTH_PASS" ]; then
        pass="$DEFAULT_AUTH_PASS"
    fi

    [ -z "$pass" ] && { warn "Пароль не может быть пустым"; pause; return; }

    sed -i "/DEFAULT_AUTH_USER=/d" "$CONF_FILE"
    sed -i "/DEFAULT_AUTH_PASS=/d" "$CONF_FILE"
    printf "DEFAULT_AUTH_USER='%s'\n" "$user" >> "$CONF_FILE"
    printf "DEFAULT_AUTH_PASS='%s'\n" "$pass" >> "$CONF_FILE"
    
    msg "Данные успешно сохранены"
    DEFAULT_AUTH_USER="$user"
    DEFAULT_AUTH_PASS="$pass"
    pause
}

do_add_vps() {
    local vps_id="${1:-}"
    local is_new=0
    [ -z "$vps_id" ] && is_new=1

    if [ "$is_new" -eq 1 ]; then
        prompt "Название сервера (например, amsterdam): "
        vps_id=$(echo "$REPLY" | tr -dc 'a-zA-Z0-9_-')
        [ -z "$vps_id" ] && { warn "Недопустимое название"; pause; return; }
    fi

    local vps_file="$VPS_DIR/$vps_id.conf"
    local v_host="" v_port="22" v_user="root"

    if [ -f "$vps_file" ]; then
        . "$vps_file"
        v_host="$VPS_HOST"; v_port="$VPS_PORT"; v_user="$VPS_USER"
    fi

    header "Настройка VPS: $vps_id"
    prompt "IP-адрес VPS [$v_host]: "
    v_host="${REPLY:-$v_host}"
    [ -z "$v_host" ] && { warn "IP обязателен"; pause; return; }

    prompt "SSH порт [$v_port]: "
    v_port="${REPLY:-$v_port}"

    prompt "SSH пользователь [$v_user]: "
    v_user="${REPLY:-$v_user}"

    # Настройка ключей
    ensure_ssh_key
    
    msg "Настраиваю доступ по SSH-ключу для $v_host..."
    
    # Копирование ключа (пароль запросит сама система)
    local ssh_exec="/opt/bin/ssh"
    [ ! -f "$ssh_exec" ] && ssh_exec="ssh"
    local copy_id="/opt/bin/ssh-copy-id"
    [ ! -f "$copy_id" ] && copy_id="ssh-copy-id"
    
    printf "  ${YELLOW}Сейчас будет запрошен пароль VPS для копирования ключа${NC}\n"
    $copy_id -o StrictHostKeyChecking=no -i "$SSH_KEY.pub" -p "$v_port" "$v_user@$v_host" 2>/dev/null || {
        cat "$SSH_KEY.pub" | $ssh_exec -o StrictHostKeyChecking=no -p "$v_port" "$v_user@$v_host" \
            "mkdir -p ~/.ssh && cat >> ~/.ssh/authorized_keys && chmod 700 ~/.ssh && chmod 600 ~/.ssh/authorized_keys"
    }

    if ! $ssh_exec -o StrictHostKeyChecking=no -o ConnectTimeout=10 -i "$SSH_KEY" -p "$v_port" "$v_user@$v_host" "echo ok" >/dev/null 2>&1; then
        err "Ошибка подключения по ключу. Убедитесь, что пароль введен верно."
        pause; return
    fi

    # Сохраняем (БЕЗ ПАРОЛЯ)
    cat > "$vps_file" <<EOF
VPS_HOST="$v_host"
VPS_PORT="$v_port"
VPS_USER="$v_user"
VPS_AUTH="key"
EOF
    chmod 600 "$vps_file"
    msg "Профиль '$vps_id' сохранён (авторизация по ключу)."

    # Настройка Nginx на новом VPS
    msg "Настройка окружения на VPS..."
    VPS_HOST="$v_host" VPS_PORT="$v_port" VPS_USER="$v_user" VPS_AUTH="key"
    ssh_cmd "
        if ! command -v nginx >/dev/null 2>&1; then
            apt-get update -qq && apt-get install -y -qq nginx psmisc || (yum update -y && yum install -y nginx psmisc)
        else
            apt-get update -qq && apt-get install -y -qq psmisc || yum install -y psmisc
        fi
        mkdir -p /etc/nginx/sites-enabled
        grep -q 'sites-enabled' /etc/nginx/nginx.conf || sed -i '/http {/a\    include /etc/nginx/sites-enabled/*.conf;' /etc/nginx/nginx.conf
        command -v certbot >/dev/null 2>&1 || (apt-get update -qq && apt-get install -y -qq certbot python3-certbot-nginx || yum install -y certbot python3-certbot-nginx)
        # Настройка Nginx Stream
        mkdir -p /etc/nginx/streams-enabled
        if ! grep -q 'streams-enabled' /etc/nginx/nginx.conf; then
            # Добавляем блок stream в конец файла, если его нет
            if grep -q 'stream {' /etc/nginx/nginx.conf; then
                 # Блок есть, но без нашего инклуда - добавим внутрь (сложно седом, просто в конец)
                 echo "include /etc/nginx/streams-enabled/*.conf;" >> /etc/nginx/nginx.conf
            else
                 printf "\nstream {\n    include /etc/nginx/streams-enabled/*.conf;\n}\n" >> /etc/nginx/nginx.conf
            fi
        fi

        systemctl enable nginx && systemctl start nginx
    "
    pause
}

ensure_ssh_key() {
    if [ ! -f "$SSH_KEY" ]; then
        msg "Генерирую SSH-ключ (ed25519)..."
        local keygen="/opt/bin/ssh-keygen"
        [ ! -f "$keygen" ] && keygen="ssh-keygen"
        $keygen -t ed25519 -f "$SSH_KEY" -N "" -q
        [ ! -f "$SSH_KEY.pub" ] && $keygen -y -f "$SSH_KEY" > "$SSH_KEY.pub"
        chmod 600 "$SSH_KEY"
    fi
}

# ══════════════════════════════════════════════════════════════════════
# ТОЧКА ВХОДА
# ══════════════════════════════════════════════════════════════════════
migrate_config 2>/dev/null
ensure_local_deps

# Поддержка прямых команд для init-скрипта и автоматизации
case "${1:-}" in
    start)      check_conf && do_start_all ;;
    stop)       check_conf && do_stop_all ;;
    restart)    check_conf && do_stop_all; sleep 1; do_start_all ;;
    status)
        check_conf || { err "VPS не настроен"; exit 1; }
        for f in "$SERVICES_DIR"/*.conf; do
            [ -f "$f" ] || continue
            local name=$(basename "$f" .conf)
            (
                _clear_svc_vars
                . "$f"
                
                local status="${RED}OFFLINE${NC}"
                is_running "$SVC_NAME" && status="${GREEN}ONLINE${NC}"
                
                local type="[PORT]"
                [ -n "$SVC_DOMAIN" ] && type="[DOM ]"

                local addr="$SVC_EXT_PORT"
                [ -n "$SVC_DOMAIN" ] && addr="$SVC_DOMAIN"
                
                printf "  %-15s %-7s %-20s %s\n" "$SVC_NAME" "$type" "$addr" "$status"
            )
        done
        ;;
    init-script)
        cat <<EOF > /opt/etc/init.d/S99rproxy
#!/bin/sh

case "\$1" in
start)
    /opt/bin/rproxy start
    ;;
stop)
    /opt/bin/rproxy stop
    ;;
restart)
    /opt/bin/rproxy restart
    ;;
esac
EOF
        chmod +x /opt/etc/init.d/S99rproxy
        msg "Скрипт автозагрузки создан: /opt/etc/init.d/S99rproxy"
        ;;
    -v|--version) echo "rProxy v$VERSION" ;;
    "")         main_menu ;;
    *)          main_menu ;;
esac
