find_vps_by_domain() {
    local dom="$1"
    FOUND_VPS_ID=""
    # Пытаемся получить IP через ping (BusyBox стиль)
    local ip=$(ping -c 1 "$dom" 2>/dev/null | grep -o "[0-9]\{1,3\}\.[0-9]\{1,3\}\.[0-9]\{1,3\}\.[0-9]\{1,3\}" | head -n 1)
    # Если не вышло, пробуем nslookup (парсим более надежно через grep -o)
    [ -z "$ip" ] && ip=$(nslookup "$dom" 2>/dev/null | grep "Address" | tail -n 1 | grep -o "[0-9]\{1,3\}\.[0-9]\{1,3\}\.[0-9]\{1,3\}\.[0-9]\{1,3\}" | head -n 1)
    
    [ -z "$ip" ] && return 1

    for f in "$VPS_DIR"/*.conf; do
        [ -f "$f" ] || continue
        # Используем grep для извлечения IP из конфига (быстрее и надежнее источника)
        local v_host=$(grep "VPS_HOST=" "$f" | cut -d'"' -f2)
        if [ "$v_host" = "$ip" ]; then
            FOUND_VPS_ID=$(basename "$f" .conf)
            return 0
        fi
    done
    return 1
}

select_vps_interactive() {
    SELECTED_VPS_ID=""
    while true; do
        clear_screen
        draw_box "Выберите VPS для сервиса"
        printf "\n"
        local vps_list=""
        local idx=0
        for f in "$VPS_DIR"/*.conf; do
            [ -f "$f" ] || continue
            idx=$((idx + 1))
            (
                . "$f"
                printf "  ${BOLD}%d)${NC}  %s  (${DIM}%s${NC})\n" "$idx" "$(basename "$f" .conf)" "$VPS_HOST"
            )
            [ -z "$vps_list" ] && vps_list="$(basename "$f" .conf)" || vps_list="$vps_list $(basename "$f" .conf)"
        done
        
        draw_separator
        printf "  ${BOLD}901)${NC} ➕  Добавить новый VPS\n"
        printf "  ${BOLD}0)${NC}   Назад\n"
        prompt "Выберите номер: "
        
        [ "$REPLY" = "0" ] && { SELECTED_SERVICE=""; return 1; }

        if [ "$REPLY" = "901" ]; then
            do_add_vps
            # Возвращаем последний созданный (упрощение)
            SELECTED_VPS_ID=$(ls -t "$VPS_DIR"/*.conf | head -n 1 | xargs basename | sed 's/\.conf//')
            return 0
        fi
        
        # Валидация ввода для cut
        if echo "$REPLY" | grep -qE '^[0-9]+$'; then
            SELECTED_VPS_ID=$(echo "$vps_list" | cut -d' ' -f"$REPLY")
            [ -n "$SELECTED_VPS_ID" ] && return 0
        fi
        warn "Неверный выбор. Попробуйте еще раз."
        sleep 1
    done
}

build_ttyd_command_interactive() {
    local current_cmd="$1"
    TTYD_CMD_RESULT=""
    
    while true; do
        clear_screen
        draw_box "Конструктор команды терминала"
        [ -n "$current_cmd" ] && printf "  Текущая команда: ${CYAN}%s${NC}\n\n" "$current_cmd"
        
        printf "  Выберите тип подключения:\n"
        printf "  ${BOLD}1)${NC}  Системный вход (login) — стандарт роутера\n"
        printf "  ${BOLD}2)${NC}  Оболочка (sh) — прямой вход без пароля\n"
        printf "  ${BOLD}0)${NC}  Отмена\n"
        
        prompt "Ваш выбор: "
        case "$REPLY" in
            1) TTYD_CMD_RESULT="login"; break ;;
            2) TTYD_CMD_RESULT="sh"; break ;;
            0) return 1 ;;
            *) warn "Неверный выбор" ;;
        esac
    done
    
    return 0
}


# ══════════════════════════════════════════════════════════════════════
# ДОБАВИТЬ СЕРВИС (интерактивно)
# ══════════════════════════════════════════════════════════════════════
do_add_interactive() {
    local step=1
    local name="" target="" mode="" domain="" ext_port="" use_ssl="no" vps_id="" 
    local use_ndm_auth="no" htpasswd_line=""
    local svc_type="http" # http, tcp, ttyd

    while [ "$step" -gt 0 ]; do
        clear_screen
        draw_box "Добавить новый сервис (Шаг $step/7)"
        printf "  ${DIM}Введите 0 на любом шаге для возврата назад${NC}\n\n"

        case "$step" in
            1)
                prompt "Название сервиса (латиницей, без пробелов): "
                [ "$REPLY" = "0" ] && return
                name=$(echo "$REPLY" | tr '[:upper:]' '[:lower:]' | tr ' ' '_' | tr -cd '[:alnum:]_-')
                if [ -z "$name" ]; then
                    warn "Название не может быть пустым."
                    pause
                elif [ -f "$SERVICES_DIR/$name.conf" ]; then
                    err "Сервис '$name' уже существует."
                    pause
                else
                    step=2
                fi
                ;;
            2)
                printf "  Название: ${CYAN}%s${NC}\n\n" "$name"
                printf "  ${BOLD}Тип сервиса:${NC}\n"
                printf "  ${BOLD}1)${NC} Веб (HTTP) — сайты, панели управления\n"
                printf "  ${BOLD}2)${NC} Порт (TCP) — SSH (22), БД, сырой трафик\n"
                printf "  ${BOLD}3)${NC} Терминал (ttyd) — доступ к консоли через браузер\n"
                prompt "Выберите [1]: "
                [ "$REPLY" = "0" ] && { step=1; continue; }
                case "${REPLY:-1}" in
                    1) svc_type="http" ;;
                    2) svc_type="tcp" ;;
                    3) svc_type="ttyd" ;;
                    *) warn "Неверный выбор"; pause; continue ;;
                esac
                step=3
                ;;
            3)
                printf "  Название: ${CYAN}%s${NC}\n" "$name"
                printf "  Тип:      ${CYAN}%s${NC}\n\n" "$svc_type"
                
                if [ "$svc_type" = "ttyd" ]; then
                    target="127.0.0.1:7681"
                    msg "Будет использован встроенный ttyd (порт 7681)"
                    if build_ttyd_command_interactive; then
                        ttyd_cmd="$TTYD_CMD_RESULT"
                        step=4
                    else
                        step=2
                    fi
                    continue
                fi

                prompt "Адрес локального сервиса (например, 127.0.0.1:8080): "
                [ "$REPLY" = "0" ] && { step=2; continue; }
                target="$REPLY"
                if [ -z "$target" ]; then
                    warn "Адрес не может быть пустым."
                    pause
                    continue
                fi
                step=4
                ;;
            4)
                printf "  Название: ${CYAN}%s${NC}\n" "$name"
                printf "  Цель:     ${CYAN}%s${NC}\n" "$target"
                printf "  Тип:      ${CYAN}%s${NC}\n\n" "$svc_type"
                
                printf "  Привязать к домену?\n"
                printf "  ${BOLD}1)${NC} Да — указать доменное имя (порт 443)\n"
                printf "  ${BOLD}2)${NC} Нет — указать внешний порт\n"
                prompt "Выберите [2]: "
                [ "$REPLY" = "0" ] && { step=3; continue; }
                mode="${REPLY:-2}"
                step=5
                ;;
            5)
                if [ "$mode" = "1" ]; then
                    prompt "Доменное имя (например, mysite.example.com): "
                    [ "$REPLY" = "0" ] && { step=4; continue; }
                    domain=$(echo "$REPLY" | tr '[:upper:]' '[:lower:]')
                    if [ -z "$domain" ]; then
                        warn "Домен не указан."
                        pause
                        continue
                    fi
                    
                    ext_port=443
                    prompt "Внешний порт [$ext_port]: "
                    [ "$REPLY" = "0" ] && { step=5; continue; }
                    ext_port="${REPLY:-$ext_port}"

                    local conflict=""
                    for f in "$SERVICES_DIR"/*.conf; do
                        [ -f "$f" ] || continue
                        local c_domain=$(grep "SVC_DOMAIN=" "$f" | cut -d'"' -f2)
                        local c_port=$(grep "SVC_EXT_PORT=" "$f" | cut -d'"' -f2)
                        if [ "$c_domain" = "$domain" ] && [ "$c_port" = "$ext_port" ]; then
                            conflict=$(basename "$f" .conf)
                            break
                        fi
                    done
                    
                    if [ -n "$conflict" ]; then
                        err "Домен '$domain' на порту '$ext_port' уже используется сервисом '$conflict'"
                        pause
                    else
                        use_ssl="yes"
                        if [ -z "$CERTBOT_EMAIL" ]; then
                            prompt "Введите Email для Certbot: "
                            [ "$REPLY" = "0" ] && continue # Переспросит домен
                            CERTBOT_EMAIL="$REPLY"
                            sed -i "/CERTBOT_EMAIL=/d" "$CONF_FILE"
                            echo "CERTBOT_EMAIL=\"$CERTBOT_EMAIL\"" >> "$CONF_FILE"
                        fi
                        step=6
                    fi
                else
                    ext_port=$(next_free_ext_port)
                    prompt "Внешний порт [$ext_port]: "
                    [ "$REPLY" = "0" ] && { step=4; continue; }
                    ext_port="${REPLY:-$ext_port}"
                    domain=""
                    use_ssl="no"
                    step=6
                fi
                ;;
            6)
                # Автоопределение VPS если домен
                if [ -n "$domain" ] && [ -z "$vps_id" ]; then
                    msg "Проверяю куда направлен домен $domain..."
                    if find_vps_by_domain "$domain"; then
                        vps_id="$FOUND_VPS_ID"
                        msg "Домен $domain указывает на ваш VPS '$vps_id'."
                        sleep 1
                    fi
                fi

                if [ -n "$vps_id" ]; then
                    printf "  Выбран VPS: ${CYAN}%s${NC}\n" "$vps_id"
                    prompt "Изменить VPS? (д/н) [н]: "
                    [ "$REPLY" = "0" ] && { step=5; continue; }
                    if [ "${REPLY:-н}" = "д" ] || [ "${REPLY:-н}" = "y" ]; then
                        vps_id=""
                    fi
                fi

                if [ -z "$vps_id" ]; then
                    select_vps_interactive || { step=5; continue; }
                    vps_id="$SELECTED_VPS_ID"
                fi
                
                [ -n "$vps_id" ] && step=7
                ;;
            7)
                if select_auth_interactive; then
                    use_ndm_auth="$AUTH_RESULT_ENABLED"
                    htpasswd_line="$AUTH_RESULT_HTPASSWD"
                    step=8
                else
                    step=6
                fi
                ;;
            8)
                load_vps "$vps_id" || { err "Ошибка загрузки VPS"; step=6; continue; }
                local t_host="${target%:*}"
                local t_port="${target#*:}"
                [ "$t_host" = "$t_port" ] && { t_port="$t_host"; t_host="127.0.0.1"; }
                local tunnel_port=$(next_free_port)

                draw_separator
                printf "  ${BOLD}Сервис:${NC}        $name\n"
                printf "  ${BOLD}VPS:${NC}           $vps_id ($VPS_HOST)\n"
                printf "  ${BOLD}Цель:${NC}          $t_host:$t_port\n"
                printf "  ${BOLD}Туннель:${NC}       порт $tunnel_port\n"
                [ -n "$domain" ] && printf "  ${BOLD}Домен:${NC}         $domain\n"
                printf "  ${BOLD}Внешний порт:${NC}  $ext_port\n"
                printf "  ${BOLD}Тип прокси:${NC}    $svc_type\n"
                printf "  ${BOLD}Авторизация:${NC}   $use_ndm_auth\n"
                draw_separator

                prompt "Всё верно? Добавить сервис? (д/н) [д]: "
                if [ "$REPLY" = "0" ]; then step=7; continue; fi
                if [ "${REPLY:-д}" != "д" ] && [ "${REPLY:-д}" != "y" ]; then
                    msg "Отменено"
                    pause
                    return
                fi

                msg "Добавляю сервис '$name'..."
                local tmp="/tmp/rproxy_$name.conf"
                local remote_path="$REMOTE_NGINX_DIR/rproxy_$name.conf"
                
                if [ "$svc_type" = "tcp" ]; then
                    generate_nginx_stream_conf "$name" "$tunnel_port" "$ext_port" "$tmp" "$domain"
                    remote_path="$REMOTE_NGINX_STREAMS_DIR/rproxy_$name.conf"
                    # Гарантируем наличие директории и инклуда в nginx.conf
                    ssh_cmd "
                        mkdir -p $REMOTE_NGINX_STREAMS_DIR
                        if ! grep -q 'streams-enabled' /etc/nginx/nginx.conf; then
                            if grep -q 'stream {' /etc/nginx/nginx.conf; then
                                echo 'include $REMOTE_NGINX_STREAMS_DIR/*.conf;' >> /etc/nginx/nginx.conf
                            else
                                printf '\nstream {\n    include $REMOTE_NGINX_STREAMS_DIR/*.conf;\n}\n' >> /etc/nginx/nginx.conf
                            fi
                        fi
                    " >/dev/null 2>&1
                else
                    generate_nginx_conf "$name" "$t_host" "$t_port" "$tunnel_port" "$domain" "$ext_port" "$use_ndm_auth" "$tmp" "$svc_type"
                fi

                if [ "$use_ndm_auth" = "yes" ]; then
                    local ht_tmp="/tmp/rproxy_$name.htpasswd"
                    echo "$htpasswd_line" > "$ht_tmp"
                    scp_cmd "$ht_tmp" "$VPS_USER@$VPS_HOST:/etc/nginx/rproxy_$name.htpasswd"
                    rm -f "$ht_tmp"
                fi

                # Радикальное изменение: сначала ВСЕГДА деплоим конфиг БЕЗ SSL, даже если он выбран.
                # Это нужно, чтобы Nginx на VPS корректно запустился и Certbot смог пройти проверку домена.
                generate_nginx_conf "$name" "$t_host" "$t_port" "$tunnel_port" "$domain" "$ext_port" "$use_ndm_auth" "$tmp" "no" "$svc_type"
                
                scp_cmd "$tmp" "$VPS_USER@$VPS_HOST:$remote_path" || { err "Ошибка деплоя nginx"; rm -f "$tmp"; pause; step=8; continue; }
                rm -f "$tmp"
                msg "Перезапуск Nginx на VPS..."
                ssh_cmd "nginx -t" || { err "Ошибка конфигурации Nginx на VPS!"; return 1; }
ssh_cmd "systemctl reload nginx"

                if [ "$use_ssl" = "yes" ]; then
                    msg "Проверяю наличие SSL для $domain на VPS..."
                    if check_remote_ssl "$domain"; then
                        msg "Обнаружен существующий сертификат для $domain! Использую его."
                        if [ "$svc_type" = "tcp" ]; then
                            generate_nginx_stream_conf "$name" "$tunnel_port" "$ext_port" "$tmp" "$domain"
                        else
                            generate_nginx_conf "$name" "$t_host" "$t_port" "$tunnel_port" "$domain" "$ext_port" "$use_ndm_auth" "$tmp" "yes" "$svc_type"
                        fi
                        scp_cmd "$tmp" "$VPS_USER@$VPS_HOST:$remote_path"
                        ssh_cmd "nginx -t" || { err "Ошибка конфигурации Nginx на VPS!"; return 1; }
ssh_cmd "systemctl reload nginx"
                    else
                        msg "Получаю SSL через Certbot (может занять время)..."
                        # Для TCP через домен Certbot должен работать через 80 порт (http-01)
                        # Поэтому перед certbot должен быть временный http конфиг, но в do_add_interactive 
                        # мы уже задеплоили начальный конфиг (в generate_nginx_stream_conf без SSL если нет domain? нет, там всегда ssl если domain).
                        # Хм, для TCP домена нужно сначала поднять 80 порт для проверки.
                        if [ "$svc_type" = "tcp" ]; then
                             # Временный HTTP конфиг для проверки домена через Certbot
                             cat > "$tmp" << EOF
server {
    listen 80;
    server_name $domain;
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }
}
EOF
                             scp_cmd "$tmp" "$VPS_USER@$VPS_HOST:$REMOTE_NGINX_DIR/certbot_temp_$name.conf"
                             ssh_cmd "mkdir -p /var/www/html && nginx -t && systemctl reload nginx"
                             ssh_cmd "certbot certonly --webroot -w /var/www/html -d $domain --non-interactive --agree-tos -m $CERTBOT_EMAIL" || warn "Certbot вернул ошибку"
                             ssh_cmd "rm -f $REMOTE_NGINX_DIR/certbot_temp_$name.conf && systemctl reload nginx"
                             
                             # Теперь деплоим финальный TCP SSL конфиг
                             generate_nginx_stream_conf "$name" "$tunnel_port" "$ext_port" "$tmp" "$domain"
                             scp_cmd "$tmp" "$VPS_USER@$VPS_HOST:$remote_path"
                             ssh_cmd "nginx -t && systemctl reload nginx" >/dev/null 2>&1
                        else
                             ssh_cmd "certbot --nginx -d $domain --non-interactive --agree-tos -m $CERTBOT_EMAIL" || warn "Certbot вернул ошибку"
                        fi
                    fi
                fi

                {
                    printf 'SVC_NAME="%s"\n' "$name"
                    printf 'SVC_VPS="%s"\n' "$vps_id"
                    printf 'SVC_TARGET_HOST="%s"\n' "$t_host"
                    printf 'SVC_TARGET_PORT="%s"\n' "$t_port"
                    printf 'SVC_TUNNEL_PORT="%s"\n' "$tunnel_port"
                    printf 'SVC_EXT_PORT="%s"\n' "$ext_port"
                    printf 'SVC_DOMAIN="%s"\n' "$domain"
                    printf 'SVC_SSL="%s"\n' "$use_ssl"
                    printf 'SVC_NDM_AUTH="%s"\n' "$use_ndm_auth"
                    printf "SVC_HTPASSWD='%s'\n" "$htpasswd_line"
                    printf 'SVC_TYPE="%s"\n' "$svc_type"
                    [ -n "$ttyd_cmd" ] && printf 'SVC_TTYD_CMD="%s"\n' "$ttyd_cmd"
                    printf 'SVC_ENABLED="yes"\n'
                } > "$SERVICES_DIR/$name.conf"

                msg "Сервис '$name' добавлен!"
                do_start_service "$name"
                pause
                return
                ;;
        esac
    done
}

